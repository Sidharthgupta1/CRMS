# ─────────────────────────────────────────────────────────────
# Motherson CRMS — Environment Configuration
# Place this file in:  crms-backend\.env
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Oracle Instant Client — REQUIRED for Thick mode (NNE encryption / ORA-12660)
# Set this to your Oracle Instant Client folder path.
# Download from: https://www.oracle.com/database/technologies/instant-client/winx64-64-downloads.html
# Common Windows paths — uncomment the one that matches your installation:
ORACLE_CLIENT_LIB=C:\Oracle\instantclient_21_3\instantclient_23_8
# ORACLE_CLIENT_LIB=C:\Oracle\instantclient_23_8
# ORACLE_CLIENT_LIB=C:\oracle\instantclient_21_3
# ORACLE_CLIENT_LIB=C:\instantclient_21_3

# Oracle Database — ebs_MSWILDEV
DB_USER=APPS
DB_PASSWORD=apps123
DB_CONNECTION_STRING=mswildevdb.sharedsnpvtclie.dcvcn01.oraclevcn.com:1521/ebs_MSWILDEV
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60

# JWT Auth — change these secrets in production!
JWT_SECRET=motherson_crms_jwt_secret_key_2025_mswildev
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=motherson_crms_refresh_secret_key_2025_mswildev
JWT_REFRESH_EXPIRES_IN=7d

# CORS — allow local frontend and any Motherson domain
CORS_ORIGIN=http://localhost:3000,null

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
