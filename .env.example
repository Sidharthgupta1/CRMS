# ─────────────────────────────────────────────
# Motherson CRMS — Environment Configuration
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Oracle Instant Client — Required for NNE/Thick mode (ORA-12660)
# Download: https://www.oracle.com/database/technologies/instant-client/winx64-64-downloads.html
ORACLE_CLIENT_LIB=C:\Oracle\instantclient_21_3

# Oracle Database
DB_USER=crms_user
DB_PASSWORD=your_secure_password_here
DB_CONNECTION_STRING=localhost:1521/ORCL
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60

# JWT Auth
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8080,null,https://crms.motherson.com

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Sequence seeds (set to match your Oracle sequences if migrating)
RELEASE_SEQ_START=11972
TASK_SEQ_START=15932

# ─────────────────────────────────────────────
# ServiceNow Integration
# ─────────────────────────────────────────────
# Set SNOW_INSTANCE to enable. Leave blank to disable.
# Format: your-instance.service-now.com  (NO https://)

# Your ServiceNow instance hostname
SNOW_INSTANCE=your-instance.service-now.com

# Auth type: basic (simpler) or oauth (recommended for production)
SNOW_AUTH_TYPE=basic

# ServiceNow user credentials (needs itil + change_manager roles)
SNOW_USERNAME=crms_integration
SNOW_PASSWORD=your_snow_password

# OAuth 2.0 (only needed if SNOW_AUTH_TYPE=oauth)
# Create in SNow: System OAuth > Application Registry > New
SNOW_CLIENT_ID=
SNOW_CLIENT_SECRET=

# Shared secret for validating incoming webhooks from ServiceNow
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SNOW_WEBHOOK_SECRET=generate_a_random_32_char_secret_here

# Set to false to disable On Hold / Cancelled state syncing
SNOW_SYNC_ON_HOLD=true

# Set to true to log all SNow calls without actually sending them (testing)
SNOW_DRY_RUN=false
