# ─────────────────────────────────────────────
# Motherson CRMS — Environment Configuration
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Oracle Database
DB_USER=APPS
DB_PASSWORD=apps123
DB_CONNECTION_STRING=mswildevdb.sharedsnpvtclie.dcvcn01.oraclevcn.com:1521/ebs_MSWILDEV
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60

# JWT Auth
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8080,https://crms.motherson.com,http://10.240.182.45:3000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

#SSO 

SSO_SHARED_SECRET=motherson_ebs_sso_secret_2025

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Sequence seeds (set to match your Oracle sequences if migrating)
RELEASE_SEQ_START=11972
TASK_SEQ_START=15932
